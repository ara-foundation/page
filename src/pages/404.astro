---
import MinimalDarkLayout from "@/layouts/MinimalDarkLayout.astro";
---

<MinimalDarkLayout title="Not Found">
  <main class="mx-auto max-w-2xl px-6 py-20 text-center">
    <h1 class="text-4xl font-bold text-neutral-900 dark:text-white">404</h1>
    <p class="mt-4 text-neutral-600 dark:text-neutral-400">
      The page you are looking for does not exist.
    </p>
    <a
      href="/"
      class="mt-8 inline-block rounded-md bg-neutral-900 px-4 py-2 text-white hover:bg-neutral-700 dark:bg-white dark:text-neutral-900 dark:hover:bg-neutral-200"
    >
      Back Home
    </a>
  </main>
</MinimalDarkLayout>
