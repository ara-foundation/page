              <text x="1020" y="266" class="diagram-note" text-anchor="middle"
                >source code of app</text
              >
            </g>

            <g class="diagram-source">
              <g>
                <rect x="960" y="290" width="120" height="72" rx="18"></rect>
                <rect x="970" y="302" width="100" height="14" rx="7"></rect>
                <rect x="970" y="324" width="100" height="14" rx="7"></rect>
                <rect x="970" y="346" width="100" height="14" rx="7"></rect>
              </g>
              <text x="1020" y="390" class="diagram-label" text-anchor="middle"
                >Blockchain</text
              >
              <text x="1020" y="411" class="diagram-note" text-anchor="middle"
