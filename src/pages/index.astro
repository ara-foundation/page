              <circle cx="148" cy="215" r="7"></circle>
              <path d="M 108 240 Q 130 258 152 240"></path>
              <line x1="130" y1="160" x2="130" y2="145"></line>
              <circle cx="130" cy="138" r="8"></circle>
            </g>
