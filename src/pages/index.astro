---
import MinimalDarkLayout from "@/layouts/MinimalDarkLayout.astro";
import SocialLink from "@/components/utilitified_decorations/SocialLink";
import { socialLinks } from "@/types/ara";

const whitepaperUrl =
  "https://docs.google.com/document/d/1Zls4ORhzHje0t6WPOlAw-IjzizotYrmwCPElaCHFPz8/edit?usp=sharing";

const footerSocial = [
  socialLinks.twitter,
  socialLinks.bluesky,
  socialLinks.linkedin,
];
---

<MinimalDarkLayout title="Ara">
  <div
    class="mx-auto max-w-3xl px-6 pb-24 pt-12 text-left md:px-8 md:pt-16 [&_p]:text-pretty [&_li]:text-pretty"
  >
    <!-- Hero -->
    <section class="space-y-8">
      <p
        class="text-xs font-medium uppercase tracking-[0.2em] text-neutral-500"
      >
        Web3
      </p>
      <h1
        class="text-3xl font-normal leading-tight text-white md:text-4xl md:leading-tight"
      >
        Web3 is a creative workspace built on collective wisdom.
      </h1>
      <div class="space-y-4 text-base leading-relaxed text-neutral-300">
        <p>
          The first open protocol designed to build apps, create content, and
          manage data. Join the movement that unlocks collective power, rewards
          creative contributions, and decentralizes discovery, all without
          compromising privacy or sacrificing speed.
        </p>
      </div>
      <div class="flex flex-wrap gap-x-8 gap-y-3 text-sm font-medium">
        <a
          href={whitepaperUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary text-white decoration-white/30 underline-offset-4 transition-colors hover:decoration-white"
        >
          Read whitepaper on bitcointalk →
        </a>
      </div>
    </section>

    <!-- History -->
    <section class="mt-20 border-t border-white/10 pt-16 md:mt-24 md:pt-20">
      <p
        class="text-xs font-medium uppercase tracking-[0.2em] text-neutral-500"
      >
        How we got here: a brief history
      </p>
      <h2 class="mt-4 text-2xl font-normal text-white md:text-3xl">
        First came the speech. With it, man became a creative workspace.
      </h2>
      <p class="mt-6 text-base leading-relaxed text-neutral-300">
        The first era of humanity was built on the power of speech. This was
        necessary but not sufficient. The whitepaper traces five eras—and the
        gaps that set up the next one:
      </p>
      <ol
        class="mt-8 grid list-none grid-cols-[1.75rem_1fr] gap-x-4 gap-y-6 text-neutral-300"
      >
        <li class="contents">
          <span
            class="pt-0.5 text-right font-mono text-sm tabular-nums text-neutral-500"
            >1.</span
          >
          <span class="leading-relaxed">
            The first era of human civilization was built on speech. It was the
            era of the spoken word.
          </span>
        </li>
        <li class="contents">
          <span
            class="pt-0.5 text-right font-mono text-sm tabular-nums text-neutral-500"
            >2.</span
          >
          <span class="leading-relaxed">
            The second era was built on writing. It was the era of the written
            word—the book and the library.
          </span>
        </li>
        <li class="contents">
          <span
            class="pt-0.5 text-right font-mono text-sm tabular-nums text-neutral-500"
            >3.</span
          >
          <span class="leading-relaxed">
            The third era is built on the internet. It is the era of the digital
            word—the website and the web.
          </span>
        </li>
        <li class="contents">
          <span
            class="pt-0.5 text-right font-mono text-sm tabular-nums text-neutral-500"
            >4.</span
          >
          <span class="leading-relaxed">
            The fourth era is built on Web3. It is the era of the decentralized
            word—the protocol and the network.
          </span>
        </li>
        <li class="contents">
          <span
            class="pt-0.5 text-right font-mono text-sm tabular-nums text-neutral-500"
            >5.</span
          >
          <span class="leading-relaxed">
            The fifth era is built on the creative workspace. It is the era of
            collective wisdom.
          </span>
        </li>
      </ol>
    </section>

    <!-- The solution -->
    <section
      id="components"
      class="mt-20 border-t border-white/10 pt-16 md:mt-24 md:pt-20"
    >
      <p
        class="text-xs font-medium uppercase tracking-[0.2em] text-neutral-500"
      >
        The solution
      </p>
      <h2 class="mt-4 text-2xl font-normal text-white md:text-3xl">
        Three components. One coherent system.
      </h2>
      <div class="mt-10 space-y-10">
        <div class="border-b border-white/10 pb-10">
          <p
            class="text-xs font-medium uppercase tracking-[0.15em] text-neutral-500"
          >
            Protocol
          </p>
          <p class="mt-1 text-sm font-medium text-neutral-200">Arada</p>
          <p class="mt-3 text-base leading-relaxed text-neutral-300">
            The protocol is the foundation of the network. It is a set of rules
            that govern how data is stored, shared, and accessed. It is open,
            transparent, and decentralized.
          </p>
        </div>
        <div class="border-b border-white/10 pb-10">
          <p
            class="text-xs font-medium uppercase tracking-[0.15em] text-neutral-500"
          >
            Application
          </p>
          <p class="mt-1 text-sm font-medium text-neutral-200">
            Shared consensus &amp; semantics
          </p>
          <p class="mt-3 text-base leading-relaxed text-neutral-300">
            A protocol agreement by shared consensus. Ara semantics and
            <code
              class="rounded-md bg-white/10 px-2 py-0.5 font-mono text-sm text-neutral-200"
              >ara.json</code
            >
            produce a credible description of software behavior. The result is a common,
            universal language across the network.
          </p>
        </div>
        <div>
          <p
            class="text-xs font-medium uppercase tracking-[0.15em] text-neutral-500"
          >
            Interface
          </p>
          <p class="mt-1 text-sm font-medium text-neutral-200">Maydan</p>
          <p class="mt-3 text-base leading-relaxed text-neutral-300">
            A decentralized interface that allows anyone to build and use
            applications. It sits on top of the protocol and opens space for
            new, innovative ways to interact with data.
          </p>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="mt-20 border-t border-white/10 pt-16 md:mt-24 md:pt-20">
      <p
        class="text-xs font-medium uppercase tracking-[0.2em] text-neutral-500"
      >
        How it works
      </p>
      <h2 class="mt-4 text-2xl font-normal text-white md:text-3xl">
        From build to discovery
      </h2>
      <ol
        class="mt-10 grid list-none grid-cols-[1.75rem_1fr] gap-x-4 gap-y-6 text-neutral-300"
      >
        <li class="contents">
          <span
            class="pt-0.5 text-right font-mono text-sm tabular-nums text-neutral-500"
            >1.</span
          >
          <span class="leading-relaxed">
            A developer creates a new tool or application using the Ara
            framework and
            <code class="rounded bg-white/10 px-1.5 py-0.5 font-mono text-sm"
              >ara.json</code
            >
            to describe and ship behavior.
          </span>
        </li>
        <li class="contents">
          <span
            class="pt-0.5 text-right font-mono text-sm tabular-nums text-neutral-500"
            >2.</span
          >
          <span class="leading-relaxed">
            The application is deployed to the decentralized network—registered
            on
            <strong class="font-medium text-neutral-200">Arada</strong> and reachable
            across the stack.
          </span>
        </li>
        <li class="contents">
          <span
            class="pt-0.5 text-right font-mono text-sm tabular-nums text-neutral-500"
            >3.</span
          >
          <span class="leading-relaxed">
            Users work through <strong class="font-medium text-neutral-200"
              >Maydan</strong
            >: discovery and access to applications and services without relying
            on a single central authority.
          </span>
        </li>
        <li class="contents">
          <span
            class="pt-0.5 text-right font-mono text-sm tabular-nums text-neutral-500"
            >4.</span
          >
          <span class="leading-relaxed">
            Automatic discovery and indexing—driven in part by
            <strong class="font-medium text-neutral-200">Aramak</strong>—helps
            people find content and data without a centralized search
            gatekeeper.
          </span>
        </li>
      </ol>
    </section>

    <!-- A new way to build -->
    <section class="mt-20 border-t border-white/10 pt-16 md:mt-24 md:pt-20">
      <p
        class="text-xs font-medium uppercase tracking-[0.2em] text-neutral-500"
      >
        A new way to build
      </p>
      <h2 class="mt-4 text-2xl font-normal text-white md:text-3xl">
        More than a toolkit
      </h2>
      <p class="mt-6 text-base leading-relaxed text-neutral-300">
        The Ara framework is more than just a set of tools. It is a new way to
        build applications and services that are decentralized, open, and
        transparent.
      </p>
      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <article
          class="rounded-xl border border-white/10 bg-white/[0.03] p-6 md:p-8"
        >
          <h3
            class="text-sm font-medium uppercase tracking-wide text-neutral-400"
          >
            A protocol agreement
          </h3>
          <p class="mt-4 text-sm leading-relaxed text-neutral-300">
            “This software is non-toxic, and business or personal.” Respects
            users. Built for public, verifiable contributions.
          </p>
        </article>
        <article
          class="rounded-xl border border-white/10 bg-white/[0.03] p-6 md:p-8"
        >
          <h3
            class="text-sm font-medium uppercase tracking-wide text-neutral-400"
          >
            Marketplace of logic components
          </h3>
          <p class="mt-4 text-sm leading-relaxed text-neutral-300">
            Compose logic components, or reshape interface elements so
            applications can manipulate data the way you intend. The choice is
            yours to shape.
          </p>
        </article>
      </div>
    </section>

    <!-- The future of the web -->
    <section class="mt-20 border-t border-white/10 pt-16 md:mt-24 md:pt-20">
      <p
        class="text-xs font-medium uppercase tracking-[0.2em] text-neutral-500"
      >
        The future of the web
      </p>
      <h2 class="mt-4 text-2xl font-normal text-white md:text-3xl">
        The network is built on collective wisdom.
      </h2>
      <p class="mt-6 text-base leading-relaxed text-neutral-300">
        The network is built on the contributions of its users. It is built on
        the collective wisdom of its members, and it is this wisdom that drives
        the network forward.
      </p>
      <ul
        class="mt-8 grid list-none grid-cols-[1.25rem_1fr] gap-x-4 gap-y-5 text-neutral-300"
      >
        <li class="contents">
          <span class="pt-1 text-neutral-500" aria-hidden="true">•</span>
          <span>Each node has an equal voice.</span>
        </li>
        <li class="contents">
          <span class="pt-1 text-neutral-500" aria-hidden="true">•</span>
          <span>Users can contribute to the development of the network.</span>
        </li>
        <li class="contents">
          <span class="pt-1 text-neutral-500" aria-hidden="true">•</span>
          <span>Built on the collective wisdom of the users.</span>
        </li>
        <li class="contents">
          <span class="pt-1 text-neutral-500" aria-hidden="true">•</span>
          <span>Open and transparent, with no central authority.</span>
        </li>
        <li class="contents">
          <span class="pt-1 text-neutral-500" aria-hidden="true">•</span>
          <span>
            The network is built on the power of the protocol and the network.
          </span>
        </li>
      </ul>
    </section>

    <!-- Get started -->
    <section
      id="get-started"
      class="mt-20 border-t border-white/10 pt-16 md:mt-24 md:pt-20"
    >
      <h2 class="text-2xl font-normal text-white md:text-3xl">Get started</h2>
      <p class="mt-6 text-base leading-relaxed text-neutral-300">
        The Ara framework is the foundation of the new internet. It is the
        foundation of a new way to build applications and services that are
        decentralized, open, and transparent.
      </p>
      <a
        href={whitepaperUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-8 inline-block text-sm font-medium text-white underline decoration-white/30 underline-offset-4 transition-colors hover:decoration-white"
      >
        Join the network →
      </a>
    </section>

    <footer
      class="mt-20 border-t border-white/10 pt-10 text-sm text-neutral-500"
      aria-label="Site footer"
    >
      <div
        class="flex flex-col gap-10 sm:flex-row sm:flex-wrap sm:items-start sm:justify-between"
      >
        <nav
          class="flex flex-row gap-3 text-neutral-400"
          aria-label="Primary footer links"
        >
          <a
            href={whitepaperUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="w-fit hover:text-neutral-200"
          >
            Whitepaper
          </a>
          <a href="/about" class="w-fit hover:text-neutral-200">About Me</a>
        </nav>
        <div
          class="flex flex-wrap items-center gap-2"
          aria-label="Social media"
        >
          {
            footerSocial.map((link) => (
              <SocialLink
                client:load
                link={link}
                className="flex h-10 w-10 items-center justify-center rounded-lg border border-white/10 bg-white/[0.03] text-neutral-400 transition-colors hover:border-white/20 hover:bg-white/[0.06] hover:text-white"
              />
            ))
          }
        </div>
      </div>
    </footer>
  </div>
</MinimalDarkLayout>
