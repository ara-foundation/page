---
import MinimalDarkLayout from "@/layouts/MinimalDarkLayout.astro";
import SocialLink from "@/components/utilitified_decorations/SocialLink";
import Link from "@/components/custom-ui/Link";
import { companyInfo, socialLinks } from "@/types/ara";

const joinSocial = [
  socialLinks.linkedin,
  socialLinks.twitter,
  socialLinks.bluesky,
];
---

<MinimalDarkLayout title="Ara">
  <div class="ara-main">
    <div class="hero">
      <h1 class="hero-slogan">
        <em>Creative workspace</em> 💻<br />
        on collective wisdom 🌐
      </h1>
      <p class="hero-subtitle">
        Ara is a set open-source technologies and protocols to organize Web
        semantically. <br />It brings ownership over computer to users. Lead
        designer is
        <a href="https://ahmetson.com/">Medet Ahmetson</a>.
      </p>
      <div class="hero-cta">
        <Link uri="https://cascadefund.org" asNewTab focus>
          Visit CascadeFund
        </Link>
        or
        <Link uri="/roadmap" className="hero-cta-link">view roadmap </Link>
      </div>
      <p class="hero-cta-subtext">
        Are you an open-source maintainer? Join our CascadeFund to organize
        open-source projects semantically.
      </p>
    </div>

    <section id="pillars">
      <p class="s-label reveal">What it means for You?</p>
      <div class="pillars reveal">
        <div class="pillar pillar-wide">
          <p class="pillar-num">01</p>
          <span class="pillar-icon">💻</span>
          <h3 class="pillar-title">Your device is your creative workspace</h3>
          <p class="pillar-body">
            Your computer is the center. Apps & UI are Lego bricks.
          </p>
          <p class="pillar-body pillar-body-top">
            Ara sets the semantic rules for the open-source apps, that OS (for
            desktop apps) or Browser (for web apps) fetches locally to turn them <a
              href="https://www.inkandswitch.com/malleable-software/"
              target="_blank"
              rel="noopener">malleable system to you</a
            >. You can create, and combine visual interfaces. Pipe apps, and
            compose them beyond what developers provided. In short it provides
          </p>
        </div>
        <div class="pillar">
          <p class="pillar-num">02</p>
          <span class="pillar-icon">🧱</span>
          <h3 class="pillar-title">
            Your data local. Apps & UI are Lego bricks
          </h3>
          <p class="pillar-body">
            Your data always stays on your local computer.
          </p>
          <p class="pillar-body pillar-body-mid">
            Meanwhile, you can create, move, and combine visual interfaces and
            pipe apps in whatever way you want.
            <br /><br />
            Ara is complementary with existing OS and Web. Turning existing apps into
            malleable, personalizable building blocks for you.
            <br /><br />
            <strong>The apps are required to be open-source.</strong>
          </p>
        </div>
        <div class="pillar">
          <p class="pillar-num">03</p>
          <span class="pillar-icon">🌐</span>
          <h3 class="pillar-title">Blockchain is collective wisdom</h3>
          <p class="pillar-body">
            The blockchain stores app <strong>semantics</strong>: what app is
            composed of, relationships to other apps, and to the user.
          </p>
          <p class="pillar-body pillar-body-mid">
            Additionally, this blockchain is a p2p recommendation engine, that
            lets you share and discover apps built with lego bricks.
            <br /><br />
            Blockchain means discoveribility by user intent, instead of attention
            grabbing.
          </p>
        </div>
      </div>
    </section>

    <section id="examples" class="examples-section">
      <h2 class="examples-heading reveal text-center">Use cases</h2>
      <p class="example-label">
        Computers communicate each other via blockchain. How you personalize
        your apps is helped by people who have same apps and similar situation.
      </p>
      <div class="example-cards reveal">
        <button class="example-card" data-comic-id="teacher" type="button">
          <div class="ec-corner ec-corner-teacher" aria-hidden="true">
            <div class="ec-window-head">
              <span class="ec-dot ec-dot-red"></span>
              <span class="ec-dot ec-dot-yellow"></span>
              <span class="ec-dot ec-dot-green"></span>
              <span class="ec-window-title">presentation.ara — slide 4</span>
            </div>
            <div class="ec-teacher-tools">
              <span class="ec-tool-cell">T</span>
              <span class="ec-tool-cell">⬜</span>
              <span class="ec-tool-cell">📷</span>
              <span class="ec-tool-cell">≡</span>
            </div>
          </div>
          <p class="ec-who">A teacher</p>
          <h3 class="ec-title">
            Building a presentation about ancient scripts
          </h3>
        </button>
        <button class="example-card" data-comic-id="programmer" type="button">
          <div class="ec-corner ec-corner-student" aria-hidden="true">
            <div class="ec-window-head">
              <span class="ec-dot ec-dot-red"></span>
              <span class="ec-dot ec-dot-yellow"></span>
              <span class="ec-dot ec-dot-green"></span>
              <span class="ec-window-title">tutorial-player</span>
            </div>
            <div class="ec-student-tools">
              <span class="ec-play-chip">▶</span>
              <span class="ec-terminal-chip">
                <span class="ec-terminal-head">main.rs</span>
                <span class="ec-terminal-row">
                  <span class="ec-terminal-prompt">&gt;</span>
                  <span class="ec-terminal-input"></span>
                  <span class="ec-terminal-cursor"></span>
                </span>
              </span>
            </div>
          </div>
          <p class="ec-who">A student</p>
          <h3 class="ec-title">Tired of pausing a video every time he types</h3>
        </button>
      </div>
    </section>

    <div class="comic-overlay" id="comicOverlay">
      <div class="comic-header">
        <button class="comic-close" id="comicCloseBtn" type="button"
          >Back</button
        >
      </div>
      <div class="comic-scroll" id="comicScroll"></div>
    </div>

    <section id="ai" class="ai-section">
      <p class="s-label reveal">Foundation for empowering AI</p>
      <div class="ai-inner">
        <div class="reveal">
          <h2 class="ai-heading">
            Ara is a foundation for local-first AI & public training data.
          </h2>
          <p class="ai-body">
            Your data stays on your device. Your computer uses open-source apps
            with semantics.
            <br /><br />
            Then any AI keeps data locally & knows all app functionality: no need
            for MCP, no need for complicated screenshot analyzing.
            <br /><br />
            The blockchain keeps the public semantics and intent-tracking data available
            for verifiable training. <strong
              >Ara blockchains becomes the first public training data for AI.</strong
            >
          </p>
        </div>
        <div class="ai-diagram reveal reveal-d">
